# Clienteiro - exemplo de configuracao
# Copie para .env e preencha com valores reais. Nunca versionar .env.

FLASK_ENV=development
FLASK_DEBUG=0
PORT=3583

# Seguranca obrigatoria em producao
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_VALUE
INTERNAL_API_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_VALUE

# Banco de dados
# Para abrir a aplicacao em modo demo/local sem banco, mantenha SKIP_DB_INIT=true.
# Para usar o painel completo, configure SUPABASE_DB_URL ou DATABASE_URL e mude SKIP_DB_INIT=false.
SKIP_DB_INIT=true
SUPABASE_DB_URL=
DATABASE_URL=

# Credenciais iniciais
# Use somente no primeiro boot. Depois remova ou troque no painel/admin.
DEFAULT_ADMIN_USER=diretor
DEFAULT_ADMIN_PASS=CHANGE_ME_STRONG_ADMIN_PASSWORD
DEFAULT_CONSULTOR_USER=consultor
DEFAULT_CONSULTOR_PASS=CHANGE_ME_STRONG_CONSULTOR_PASSWORD

# Busca e relatorios
SEARCH_MAX_RESULTS=15
SEARCH_TIMEOUT=10
LEADS_PER_REPORT=10
MAX_UPLOAD_MB=5

# Runtime
# db | live | demo | auto
LEADS_SOURCE=db
# empty | demo | live
LEADS_FALLBACK=live
ENABLE_LIVE_SCRAPING=false
ENABLE_STREAM_HARVEST=false
ENABLE_HARVEST=false
HARVEST_MAX_CYCLES=0
HARVEST_MAX_RUNTIME_MIN=0
HARVEST_SINGLE_WORKER_ALL=true
HARVEST_NICHO_CHUNK=6

# LGPD / compliance
CONSENT_VERSION=2026-03-28
LEAD_RETENTION_DAYS=180
LEGAL_BASIS_DEFAULT=consent
DPO_EMAIL=privacidade@clienteiro.com.br

# Bot status proxy opcional
BOT_STATUS_URL=http://bot:3582/status

# Integracao SaasBot opcional
SAASBOT_INTERNAL_URL=
SAASBOT_TENANT_ID=default
SAASBOT_API_SECRET=

# Kiosk
KIOSK_SECRET_COMBO=CTRL+SHIFT+U
KIOSK_EXIT_PIN=CHANGE_ME_NUMERIC_PIN
KIOSK_UNLOCK_WINDOW_SECONDS=60
KIOSK_UNLOCK_MAX_ATTEMPTS=5

# Gunicorn/Docker
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120

# Evolution API / roleta
EVOLUTION_BASE_URL=https://evolution.seudominio.com.br
EVOLUTION_INSTANCE=CHANGE_ME_INSTANCE_ID
EVOLUTION_API_KEY=CHANGE_ME_EVOLUTION_API_KEY
PRIZE_PDF_URL=https://seudominio.com.br/premio.pdf
ROULETTE_WEBHOOK_URL=http://roulette-webhook:3000/webhook/roleta
ROULETTE_REQUIRE_WHATSAPP_EXISTS=true
ROULETTE_ALLOW_QUEUE_WHEN_VALIDATION_OFFLINE=true
ROULETTE_QUEUE_FLUSH_BATCH=25

# Evolution Docker local
EVOLUTION_POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
