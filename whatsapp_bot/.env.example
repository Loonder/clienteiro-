# Clienteiro WhatsApp Bot - exemplo
# Copie para whatsapp_bot/.env e preencha localmente. Nunca versionar .env.

PORT=3582

# Deve ser exatamente igual ao INTERNAL_API_KEY do backend.
INTERNAL_API_KEY=CHANGE_ME_SAME_AS_BACKEND_INTERNAL_API_KEY

# Backend Flask acessado pelo bot.
BACKEND_HOST=backend
BACKEND_PORT=3583

# Google Service Account opcional.
GCLOUD_EMAIL=service-account@project.iam.gserviceaccount.com
GCLOUD_PRIVATE_KEY="CHANGE_ME_PRIVATE_KEY_WITH_ESCAPED_NEWLINES"

# Telefones administradores, separados por virgula, com DDI.
ADMIN_PHONES=5511999999999

# Runtime
ENABLE_BOT=false
ENABLE_MOCK_CALENDAR=false
WA_HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=

# IA opcional
GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY

# Evolution provider opcional
EVOLUTION_API_URL=https://evolution.seudominio.com.br
EVOLUTION_API_KEY=CHANGE_ME_EVOLUTION_API_KEY
EVOLUTION_INSTANCE=CHANGE_ME_INSTANCE_ID
